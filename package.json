{
  "name": "safe-x-editor",
  "version": "1.0.0",
  "description": "react parcel socket io web editor",
  "main": "index.js",
  "scripts": {
    "package": "electron-builder build --mac --publish never",
    "dev": "npx webpack --config ./webpack.config.dev.js --watch",
    "build-main": "npx webpack --config ./webpack.config.prod.js",
    "test": "ts-mocha --paths -p ./main/tsconfig.json ./main/test/**/*.spec.ts",
    "start": "parcel src/editor.html -p 8585"
  },
  "keywords": [
    "react parcel socket io web editor"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {},
  "parcelCleanPaths": [
    "dist"
  ],
  "staticFiles": {
    "staticPath": "public",
    "watcherGlob": "**"
  },
  "devDependencies": {
    "@colin-luo/tree": "^4.3.0",
    "@electron/remote": "^2.1.1",
    "@fortawesome/fontawesome-svg-core": "^6.4.2",
