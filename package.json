{
  "name": "safe-x-editor",
  "version": "1.0.0",
  "description": "react parcel socket io web editor",
  "targets": {
    "frontend": {
      "publicUrl": "./",
      "distDir": "build",
      "context": "electron-renderer",
      "source": "src/editor.html"
    }
  },
  "scripts": {
    "package-win": "electron-builder build --win --publish never",
    "package": "electron-builder build --mac --publish never",
    "dev": "npx webpack --config ./webpack.config.dev.js --watch",
    "build-main": "npx webpack --config ./webpack.config.prod.js",
    "test": "tsx --tsconfig ./main/tsconfig.json ./main/test/file.spec.ts",
    "build": "parcel build",
    "start": "parcel -p 8585  --no-hmr"
  },
  "keywords": [
    "react parcel socket io web editor"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {},
  "parcelCleanPaths": [
    "dist"
  ],
  "staticFiles": {
    "staticPath": "public",
    "watcherGlob": "**"
  },
  "devDependencies": {
    "@colin-luo/tree": "^4.3.0",
    "@electron/remote": "^2.1.1",
    "@fortawesome/fontawesome-svg-core": "^6.4.2",
    "@fortawesome/free-solid-svg-icons": "^6.4.2",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.1.1",
    "@parcel/config-default": "^2.9.3",
    "@types/electron": "1.6.10",
    "@types/estraverse": "^5.1.1",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "4.14.202",
    "@types/node": "17.0.23",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^6.6.0",
    "@typescript-eslint/parser": "^6.6.0",
    "@typescript-eslint/typescript-estree": "^6.17.0",
    "allotment": "^1.19.3",
    "autoprefixer": "^10.4.16",
    "change-case": "^4.1.2",
    "clsx": "^2.1.0",
    "cocos-html5-ts": "^1.1.5",
    "copy-webpack-plugin": "^12.0.2",
    "directory-tree": "^3.5.1",
    "electron": "^28.1.1",
    "electron-builder": "^23.0.3",
    "electron-devtools-installer": "^3.2.0",
    "electron-is-dev": "^2.0.0",
    "eslint": "^8.34.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "estraverse": "^5.3.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "handlebars": "^4.7.8",
    "image-size": "^1.1.1",
    "immer": "^10.0.3",
    "is-directory": "^0.3.1",
    "leva": "^0.10.0",
    "lodash": "^4.17.21",
    "node-dir": "^0.1.17",
    "parcel": "^2.9.3",
    "parcel-plugin-clean-easy": "^1.0.2",
    "parcel-reporter-static-files-copy": "^1.5.2",
    "parcel-resolver-ts-base-url": "^1.3.1",
    "path-browserify": "^1.0.0",
    "pluralize": "^8.0.0",
    "portscanner": "^2.2.0",
