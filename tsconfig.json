{
  "compilerOptions": {
    "baseUrl": "./src",
    "outDir": "./build",
    "jsx": "react-jsx",
    "target": "ES6",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "lib": [
      "es2017",
      "dom",
      "scripthost"
    ],
    "typeRoots": [
      "@types",
      "./node_modules/cocos-html5-ts/@types",
      "node_modules/@types"
    ],
    "moduleResolution": "node"
  },
  "include": [
    "./src/**/*"
  ],
}