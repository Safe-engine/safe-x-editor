{
  "compilerOptions": {
    "baseUrl": "./src",
    "outDir": "./build",
    "jsx": "react-jsx",
    "target": "ES6",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "strict": false,
    "lib": [
      "es2017",
      "dom",
      "scripthost"
    ],
    "typeRoots": [
      "@types",
      "node_modules/@types"
    ],
  },
  "include": [
    "@types",
    "./src/**/*"
  ],
}