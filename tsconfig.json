{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ES6",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "lib": [
      "es2017",
      "dom",
      "scripthost"
    ],
    "typeRoots": [
      "@types",
      "./node_modules/cocos-html5-ts/@types",
      "node_modules/@types"
    ],
    "moduleResolution": "node"
  },
  "exclude": [
    "vscode",
    "node_modules",
    "main",
    "build"
  ],
  "include": [
    "./src/**/*"
, "src/shared"  ],
}