{
  "name": "safex-editor",
  "displayName": "safex-editor",
  "description": "edit for safex components",
  "author": "antn9x",
  "publisher": "antn9x",
  "version": "0.5.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/Microsoft/vscode-extension-samples"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "properties": {
        "safexEditor.nodeVersion": {
          "type": "string",
          "default": "v23.10.0",
          "description": "Path or version of Node.js to use"
        }
      }
    },
    "commands": [
      {
        "command": "safex.editSettings",
        "title": "Safex: Edit Project Settings"
      },
      {
        "command": "safexEditor.openSafex",
        "title": "Edit safex component"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "safexEditor.openSafex",
          "when": "resourceExtname == .tsx",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "deploy": "vsce package",
    "vscode:prepublish": "yarn run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@colin-luo/tree": "^4.3.0",
    "@typescript-eslint/typescript-estree": "^8.35.0",
    "directory-tree": "^3.5.2",
    "estraverse": "^5.3.0",
    "fs-extra": "11.3.0",
    "glob": "11.0.3",
    "handlebars": "^4.7.8",
    "image-size": "^2.0.2",
    "lodash": "^4.17.21",
    "typescript": "5.8.3"
  }
}
